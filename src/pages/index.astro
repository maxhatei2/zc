---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header/>
		<main>
			<h1>Ziarul Crizantemelor</h1>
			<p>Bine ai venit pe site-ul Ziarul Crizantemelor! După cum vezi, ne-am mutat pe o bază nouă de site.</p>
			<p>Dacă dorești, poți vizita <a href="https://sites.google.com/view/ziarulcrizantemelor">site-ul vechi</a>.</p>
		</main>
		<Footer />
	</body>
</html>
